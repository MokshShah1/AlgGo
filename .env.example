# Firebase web app configuration.
# Copy this file to ".env" and fill in values from your Firebase project:
# Firebase console -> Project settings -> Your apps -> SDK setup and configuration.
# All variables must be present or the app will show a setup screen instead of running.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to point the app at the local Firebase emulators
# (run them with: npm run emulators). Leave blank to use the live project.
VITE_USE_FIREBASE_EMULATORS=

# ----------------------------------------------------------------------------
# Mini-lesson narration voice (optional).
# Leave everything below blank for the default "auto" behavior:
#   1) use the local neural voice server if it's running (npm run tts), else
#   2) fall back to a free, no-key online voice (StreamElements / Amazon Polly).
#
# For the most realistic, human-sounding voice (free, no API key), run:
#   npm run tts        # starts the Microsoft Edge "Neural" voice server
#   npm run dev        # in another terminal
#
# Provider: "auto" (default), "edge", "streamelements", "elevenlabs", "openai".
VITE_TTS_PROVIDER=
# StreamElements voice name, e.g. Matthew, Joanna, Brian, Amy, Salli.
VITE_TTS_VOICE=
# Local neural voice server (only change if you run it on a different port/voice):
VITE_TTS_EDGE_URL=
VITE_TTS_EDGE_VOICE=
# Premium neural voices (only used when the matching provider is selected):
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
VITE_OPENAI_API_KEY=
VITE_OPENAI_VOICE=

# ----------------------------------------------------------------------------
# AI tutor (optional). Powers the "Ask AI tutor" chat + dynamic, tailored hints.
#
# The API key lives ONLY here (this file is gitignored) and is read by the proxy
# server (server/ai-server.mjs) — it never ships in the web bundle. Run:
#   npm run ai         # starts the AI proxy on http://localhost:8787
#   npm run dev        # in another terminal
# If no key is set, the proxy returns 503 and the app uses its built-in static
# hints — nothing breaks.

# --- OpenAI (default) -------------------------------------------------------
# Your OpenAI secret key (https://platform.openai.com/api-keys). Make sure it's
# created under the right organization so it bills the right account.
OPENAI_API_KEY=
# Optional: the organization id to bill (e.g. your company org, org-...).
OPENAI_ORG=
# Models: copy exact ids from the OpenAI docs. gpt-4o is a great tutor; a smaller
# model (gpt-4o-mini) keeps hints snappy. Leave blank to use these defaults.
AI_MODEL=
AI_MODEL_FAST=

# --- Anthropic / Claude (only if you use Claude instead of OpenAI) ----------
# If set (and no OPENAI_API_KEY), the proxy uses Claude automatically.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_STYLE=          # "x-api-key" (default) or "bearer" (gateways)

# --- Shared -----------------------------------------------------------------
# Force a provider: "openai" or "anthropic" (otherwise auto-detected from keys).
AI_PROVIDER=
# Override the API base URL only for a company gateway/proxy (otherwise blank).
AI_BASE_URL=
# Port the proxy listens on (defaults to 8787). Match VITE_AI_URL if you change it.
AI_PORT=
# Where the web app finds the proxy (defaults to http://localhost:8787).
VITE_AI_URL=
